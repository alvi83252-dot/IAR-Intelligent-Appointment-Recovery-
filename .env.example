# =============================================================================
# IAR agents — example environment. Copy to .env and fill in. .env is gitignored.
# =============================================================================

# --- Model -------------------------------------------------------------------
# gemini-3.5-flash is the template default and what all three agents run on.
MODEL=gemini-3.5-flash

# --- Google credentials ------------------------------------------------------
# Standalone IAR uses the AI Studio (Developer API) key. Paste it here.
# (config.py also accepts GEMINI_API_KEY and mirrors it into GOOGLE_API_KEY.)
GOOGLE_API_KEY=your-ai-studio-key-here
# Set to true to run on Vertex AI instead (Vertex API key + GCP project).
GOOGLE_GENAI_USE_VERTEXAI=false

# --- Agent A2A URLs ----------------------------------------------------------
# Local dev defaults; docker-compose overrides these with service DNS names.
PERSONAL_AGENT_URL=http://localhost:9001/
FRONTDESK_AGENT_URL=http://localhost:9002/
RESEARCH_AGENT_URL=http://localhost:9003/

# --- Research agent: RAG + grounding ----------------------------------------
REDIS_URL=redis://localhost:6379/0
# Optional Linkup web grounding for find_alternatives (NHS sources). Blank = off.
LINKUP_API_KEY=

# --- Optional harness env-tool API (template parity; off unless set) ---------
# ENV_API_URL=http://host.docker.internal:8090
# ENV_API_TOKEN=dev-agent-token
