# =============================================================================
# IAR — Environment template (safe to commit). Copy to `.env.local` and fill in:
#     Copy-Item .env.example .env.local
# `.env.local` is gitignored — never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Demo mode (mock PAS/agents only — does NOT block SMS or email)
# -----------------------------------------------------------------------------
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Notifications: builtin (default) | live (Twilio + Gmail)
NOTIFICATIONS_MODE=builtin

# -----------------------------------------------------------------------------
# LLM — Google Gemini (CopilotKit chatbot + agents)
# Get a key: https://aistudio.google.com/apikey
# Server-side only — do not prefix with NEXT_PUBLIC_
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=

# Alternative LLM providers (optional — use when Gemini quota is depleted)
# Set CHAT_MODEL to force a provider, e.g. openai/gpt-4o-mini
# CHAT_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Provider + default model (used when an agent has no specific override).
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash

# --- Per-agent model selection ----------------------------------------------
PERSONAL_AGENT_MODEL=gemini-3.5-flash
FRONTDESK_AGENT_MODEL=gemini-3.5-flash
RESEARCH_AGENT_MODEL=gemini-3.5-flash

# -----------------------------------------------------------------------------
# Voice — ElevenLabs (accessibility: text or voice on start & confirmation)
# Get a key: https://elevenlabs.io/app/settings/api-keys
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# -----------------------------------------------------------------------------
# Google Calendar meetup booking page (shown after confirmation)
# -----------------------------------------------------------------------------
GOOGLE_MEETUP_BOOKING_URL=https://calendar.app.google/PAm4y6BTimvayDrK9
NEXT_PUBLIC_GOOGLE_MEETUP_BOOKING_URL=https://calendar.app.google/PAm4y6BTimvayDrK9

# -----------------------------------------------------------------------------
# SMS — Twilio (required for real SMS confirmations)
# https://console.twilio.com/
# Use E.164 numbers, e.g. +447700900123
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# Gmail — Google Cloud OAuth (required for real email confirmations + .ics)
# Enable Gmail API, create OAuth client, obtain refresh token with gmail.send scope
# https://console.cloud.google.com/
# -----------------------------------------------------------------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# -----------------------------------------------------------------------------
# Google Calendar (creates event + sends invite to patient email on booking)
# Can reuse GMAIL_* OAuth above — add https://www.googleapis.com/auth/calendar.events
# to your OAuth consent scopes when generating the refresh token
# https://calendar.google.com/
# -----------------------------------------------------------------------------
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary

# -----------------------------------------------------------------------------
# A2A agent URLs (when running real Python agents instead of demo mocks)
# -----------------------------------------------------------------------------
# PERSONAL_AGENT_URL=http://localhost:9001/
# RESEARCH_AGENT_URL=http://localhost:9003/
# FRONTDESK_AGENT_URL=http://localhost:9002/

# -----------------------------------------------------------------------------
# CopilotKit (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_COPILOTKIT_LICENSE_KEY=
