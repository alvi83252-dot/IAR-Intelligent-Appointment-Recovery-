# Harness env API (the a2a-hack CLI on your host)
ENV_API_URL=http://host.docker.internal:8090
CS_AGENT_URL=http://cs-agent:9002

# Per-service env API tokens (must match the harness defaults for local runs)
PERSONAL_ENV_API_TOKEN=dev-user-token
CS_ENV_API_TOKEN=dev-agent-token

# Model — gemini-3.5-flash is required for A2A hackathon marking
MODEL=gemini-3.5-flash

# Vertex AI auth via API key from GCP (Vertex AI Agent Platform → API keys)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_API_KEY=

# Next.js frontend
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
