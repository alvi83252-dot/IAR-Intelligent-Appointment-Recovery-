# =============================================================================
# IAR — Environment template (safe to commit). Copy to `.env.local` and fill in:
#     Copy-Item .env.example .env.local
# `.env.local` is gitignored — never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Demo mode (mock PAS/agents only — does NOT block SMS or email)
# -----------------------------------------------------------------------------
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# -----------------------------------------------------------------------------
# LLM — FreeLLMAPI (local, OpenAI-compatible — no cloud token costs)
# Run FreeLLMAPI via Docker (default http://localhost:3001/v1).
# Get your API key from the FreeLLMAPI setup UI after first start.
# -----------------------------------------------------------------------------
FREELLMAPI_API_KEY=freellmapi-your-key-here
FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_MODEL=llama-3.3-70b-versatile

# CopilotKit BuiltInAgent reads these (auto-synced from FREELLMAPI_* if unset):
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
CHAT_MODEL=openai/llama-3.3-70b-versatile

LLM_PROVIDER=openai
LLM_MODEL=llama-3.3-70b-versatile
PERSONAL_AGENT_MODEL=llama-3.3-70b-versatile
FRONTDESK_AGENT_MODEL=llama-3.3-70b-versatile
RESEARCH_AGENT_MODEL=llama-3.3-70b-versatile

# Chat works without any key (built-in rule-based assistant).
# Alternative cloud providers (optional):
# ANTHROPIC_API_KEY=

# Legacy Google Gemini (optional — only if LLM_PROVIDER=gemini)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=true
# MODEL=gemini-3.5-flash

# -----------------------------------------------------------------------------
# Voice — ElevenLabs (accessibility)
# -----------------------------------------------------------------------------
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# -----------------------------------------------------------------------------
# Google Calendar meetup booking page
# -----------------------------------------------------------------------------
GOOGLE_MEETUP_BOOKING_URL=https://calendar.app.google/PAm4y6BTimvayDrK9
NEXT_PUBLIC_GOOGLE_MEETUP_BOOKING_URL=https://calendar.app.google/PAm4y6BTimvayDrK9

# -----------------------------------------------------------------------------
# Gmail OAuth — sign in once at http://localhost:3000/setup
# Enable Gmail API + Google Calendar API in Google Cloud Console
# Redirect URI must match Google Cloud Console exactly (see /setup page)
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# -----------------------------------------------------------------------------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_SENDER_EMAIL=
GMAIL_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# A2A hackathon harness (Docker personal-agent + cs-agent)
# -----------------------------------------------------------------------------
ENV_API_URL=http://host.docker.internal:8090
CS_AGENT_URL=http://cs-agent:9002
PERSONAL_ENV_API_TOKEN=dev-user-token
CS_ENV_API_TOKEN=dev-agent-token

# -----------------------------------------------------------------------------
# A2A agent URLs (optional — local dev without Docker)
# -----------------------------------------------------------------------------
# PERSONAL_AGENT_URL=http://localhost:9001/
# RESEARCH_AGENT_URL=http://localhost:9003/
# FRONTDESK_AGENT_URL=http://localhost:9002/

# NEXT_PUBLIC_COPILOTKIT_LICENSE_KEY=
