# =============================================================================
# IAR — Environment template (safe to commit). Copy to .env and fill in values:
#     cp .env.example .env        # PowerShell: Copy-Item .env.example .env
# .env is gitignored; never commit a real key.
# =============================================================================

# --- LLM provider ------------------------------------------------------------
# Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Provider + default model (used when an agent has no specific override).
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash

# --- Per-agent model selection ----------------------------------------------
# Personal agent and Front Desk (customer service) agent run on Gemini Flash.
PERSONAL_AGENT_MODEL=gemini-3.5-flash
FRONTDESK_AGENT_MODEL=gemini-3.5-flash
RESEARCH_AGENT_MODEL=gemini-3.5-flash

# --- A2A service URLs (used once the Python agent servers exist) -------------
PERSONAL_AGENT_URL=http://localhost:9001/
FRONTDESK_AGENT_URL=http://localhost:9002/
RESEARCH_AGENT_URL=http://localhost:9003/
